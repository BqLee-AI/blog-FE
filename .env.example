# ============================================
# 应用配置 - API 与认证
# ============================================

# API 基础 URL
# 开发环境：使用相对路径 /api/v1，由 Vite 代理转发到后端
# 生产环境：使用完整 URL，如 https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# 可选：后端服务器地址（仅用于生产构建或参考）
# VITE_BACKEND_URL=http://172.207.24.18:8080

# ============================================
# Vite 相关配置
# ============================================

# Vite 开发服务器端口（默认 5173）
# VITE_PORT=5173

# ============================================
# 应用特性开关
# ============================================

# 启用调试模式（会输出更多日志）
# VITE_DEBUG=false
